{erl_opts, [
    % mandatory
    debug_info,
    warnings_as_errors,
    warn_export_all,
    warn_missing_spec,
    warn_untyped_record,
    warn_export_vars,

    % by default
    warn_unused_record,
    warn_bif_clash,
    warn_obsolete_guard,
    warn_unused_vars,
    warn_shadow_vars,
    warn_unused_import,
    warn_unused_function,
    warn_deprecated_function

    % at will
    % bin_opt_info
    % no_auto_import
    % warn_missing_spec_all
]}.

{shell, [{config, "config/sys.config"}]}.

{xref_checks, [
    % mandatory
    undefined_function_calls,
    undefined_functions,
    deprecated_functions_calls,
    deprecated_functions

    % at will
    % exports_not_used
]}.

{dialyzer, [
    {warnings, [
        % mandatory
        unmatched_returns,
        error_handling,
        unknown
    ]},
    {plt_apps, all_deps},
    %% eunit (TEST blocks), Common Test (?config, ct:*), httpc для SUITE
    {plt_extra_apps, [eunit, common_test, inets]}
]}.

{deps, [
    {gun, "2.1.0"},
    {jsx, "3.1.0"},
    {cowboy, "2.12.0"}
]}.

{relx, [
    {release, {bb, "0.1.0"}, [
        bb,
        sasl
    ]},

    {mode, dev},

    %% automatically picked up if the files
    %% exist but can be set manually, which
    %% is required if the names aren't exactly
    %% sys.config and vm.args
    {sys_config, "./config/sys.config"},
    {vm_args, "./config/vm.args"}

    %% the .src form of the configuration files do
    %% not require setting RELX_REPLACE_OS_VARS
    %% {sys_config_src, "./config/sys.config.src"},
    %% {vm_args_src, "./config/vm.args.src"}
]}.

{profiles, [
    {test, [
        {extra_src_dirs, [{"test", [common_test]}]}
    ]},
    %% prod is the default mode when prod
    %% profile is used, so does not have
    %% to be explicitly included like this
    {prod, [
        {relx, [
            {mode, prod}

            %% use minimal mode to exclude ERTS
            %% {mode, minimal}
        ]}
    ]}
]}.

{project_plugins, [
    {erlfmt, "1.6.2"},
    {rebar3_lint, "3.2.6"}
]}.

{erlfmt, [
    write,
    {print_width, 120},
    {files, [
        "apps/*/{src,include,test}/*.{hrl,erl}", "rebar.config", "elvis.config", "config/sys.config"
    ]}
]}.
